}
class SystemReportRow

AdminSystemReportController ..> SystemReportDAO
SystemReportDAO ..> SystemReportRow : List

newpage
title Luồng 3 - Class (Restaurant applications)

class AdminRestaurantApplicationsController {
  +doGet()
  +doPost()
  -handleList()
  -handleDetail()
  -handleUpdateStatus()
}
class RestaurantDAO {
  +findRestaurantsWithFilters()
  +getTotalFilteredRestaurants()
  +findByIdWithOwner()
  +updateRestaurantStatus()
}
class EmailService {
  {static} sendRestaurantApprovalEmail()
  {static} sendRestaurantRejectionEmail()
}
class Restaurant

AdminRestaurantApplicationsController ..> RestaurantDAO
AdminRestaurantApplicationsController ..> EmailService
RestaurantDAO ..> Restaurant

