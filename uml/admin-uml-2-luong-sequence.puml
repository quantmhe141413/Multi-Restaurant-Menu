@startuml
' =============================================================================
' PHÂN LOẠI SEQUENCE THEO LUỒNG (mỗi trang = 1 sequence + thanh == trên sơ đồ)
'
' --- LUỒNG 1: Giám sát và báo cáo (3 sequence) ---
'   1) Xem dashboard (GET)
'   2) Xem báo cáo hệ thống (GET)
'   3) Xuất CSV báo cáo (GET export)
'
' --- LUỒNG 2: Quản trị nghiệp vụ ---
'   A) Đơn đăng ký nhà hàng (4 sequence): list, detail, approve, reject
'   B) Khiếu nại (3 sequence): list, detail, update status
'   C) Cấu hình hoa hồng (3 sequence): list, edit, save rate
'   D) Lịch sử hoa hồng (1 sequence): xem lịch sử
'
' Web: https://www.plantuml.com/plantuml/uml/ — dán TOÀN BỘ file
' =============================================================================

title Luồng 1 - Giám sát và báo cáo: Xem dashboard (GET)

== Luồng 1 - Giám sát và báo cáo ==

actor Admin
participant "AdminDashboardController" as Ctrl
participant "HttpSession" as Sess
participant "RestaurantAnalyticsDAO" as DAO
database "Database" as DB
participant "admin-dashboard.jsp" as JSP

Admin -> Ctrl: GET /admin/dashboard
Ctrl -> Sess: getSession(false), getAttribute("user")
alt user null hoặc roleID khác 1
  Ctrl -> Admin: redirect /login
else admin
  Ctrl -> DAO: countAllRestaurants()
  DAO -> DB: query
  DB --> DAO
  DAO --> Ctrl
  Ctrl -> DAO: countRestaurantsByStatus (Pending, Approved, Rejected)
  DAO -> DB: query
  DB --> DAO
  DAO --> Ctrl
  Ctrl -> DAO: getTotalOrdersAllRestaurants()
  DAO -> DB
  DB --> DAO
  DAO --> Ctrl
  Ctrl -> DAO: getTotalRevenueAllRestaurants()
  DAO -> DB
  DB --> DAO
  DAO --> Ctrl
  Ctrl -> DAO: getTopRestaurantsByRevenue(10)
  DAO -> DB
  DB --> DAO
  DAO --> Ctrl
  Ctrl -> JSP: forward /views/admin/admin-dashboard.jsp
  JSP --> Admin: HTML
end

newpage
title Luồng 1 - Giám sát và báo cáo: Xem báo cáo (GET)

== Luồng 1 - Giám sát và báo cáo ==

actor Admin
participant "AdminSystemReportController" as Ctrl
participant "HttpSession" as Sess
participant "SystemReportDAO" as DAO
database "Database" as DB
participant "system-report.jsp" as JSP

Admin -> Ctrl: GET /admin/system-report ?from & to & action=view
Ctrl -> Sess: session + roleID bang 1
alt không phải admin
  Ctrl -> Admin: redirect /login
else ok
  Ctrl -> Ctrl: parse from/to, tổng hợp
  Ctrl -> DAO: getDailyReport(Date from, Date to)
  DAO -> DB: query
  DB --> DAO
  DAO --> Ctrl: rows
  Ctrl -> JSP: forward system-report.jsp
  JSP --> Admin: HTML
end

